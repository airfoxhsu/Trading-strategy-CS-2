{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            // 使用 64 位元 dotnet 建置（可跨架構編譯 x86 目標，不需要 x86 SDK）
            "command": "C:\\Program Files\\dotnet\\dotnet.exe",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/ExtremeSignalAppCS.csproj",
                "-p:Configuration=Debug",
                "-p:TargetFramework=net10.0-windows"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
