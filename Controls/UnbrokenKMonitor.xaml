<UserControl x:Class="ExtremeSignalAppCS.Controls.UnbrokenKMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Background="{StaticResource PanelDarkBg}">
        <Grid.RowDefinitions>
            <!-- 0: 標題 -->
            <RowDefinition Height="Auto"/>
            <!-- 1: 統計顯示條 -->
            <RowDefinition Height="Auto"/>
            <!-- 2: 監控顯示區 -->
            <RowDefinition Height="2*"/>
            <!-- 3: 分隔線 -->
            <RowDefinition Height="Auto"/>
            <!-- 4: 趨勢方向表單 -->
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <Border Grid.Row="0" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,0,0,1" Padding="6,4">
            <TextBlock x:Name="lblTitle" Text="🛡️ 未破分 K 停損監控" Foreground="{StaticResource SciFiGreen}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
        </Border>

        <!-- 統計顯示條 -->
        <Border Grid.Row="1" Background="{StaticResource PanelDarkBg}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="lblTotalStats" FontWeight="Bold" FontSize="13" Margin="0,0,15,0"/>
                <TextBlock x:Name="lblUnbrokenStats" FontWeight="Bold" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- 監控顯示區 -->
        <RichTextBox Grid.Row="2" x:Name="txtDisplay" IsReadOnly="True" Background="#1A1A1A" Foreground="#DCDCDC" 
                     FontFamily="Consolas" FontSize="13" BorderThickness="0" Margin="4"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <RichTextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="Copy" Header="複製選取內容 (Ctrl+C)" />
                    <MenuItem Header="複製全部內容" Click="MenuCopyDisplay_Click"/>
                </ContextMenu>
            </RichTextBox.ContextMenu>
        </RichTextBox>

        <GridSplitter Grid.Row="3" Height="3" HorizontalAlignment="Stretch" Background="#333333" Margin="0,2"/>

        <Border Grid.Row="4" Background="#1A1A1A" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,1,0,0" Padding="4">
            <RichTextBox x:Name="txtTrendHistory" IsReadOnly="True" Background="Transparent" Foreground="#DCDCDC" 
                         FontFamily="Consolas" FontSize="13" BorderThickness="0" Margin="0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <RichTextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="Copy" Header="複製選取內容 (Ctrl+C)" />
                        <MenuItem Header="複製全部內容" Click="MenuCopyTrend_Click"/>
                    </ContextMenu>
                </RichTextBox.ContextMenu>
            </RichTextBox>
        </Border>

    </Grid>
</UserControl>
