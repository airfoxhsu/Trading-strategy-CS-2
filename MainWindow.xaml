<Window x:Class="ExtremeSignalAppCS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:local="clr-namespace:ExtremeSignalAppCS"
        xmlns:controls="clr-namespace:ExtremeSignalAppCS.Controls"
        mc:Ignorable="d"
        Title="台指極值訊號自動對比 - WPF 現代高性能 DirectX 32位元版" 
        Height="800" Width="1300"
        SizeChanged="Window_SizeChanged"
        Background="{StaticResource ExtremeDarkBg}"
        FontSize="{DynamicResource GlobalFontSize}">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- 0: 頂部工具列 -->
            <RowDefinition Height="Auto"/>
            <!-- 1: 復盤回放控制面板 -->
            <RowDefinition Height="Auto"/>
            <!-- 2: 速差與極值資訊區 -->
            <RowDefinition Height="Auto"/>
            <!-- 3: 主要顯示區 (三段拉伸: 日誌看板, K線圖/停損監控, 數據表格) -->
            <RowDefinition Height="*"/>
            <!-- 4: 底部觀察參數列 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== 0. 頂部工具列 ==================== -->
        <Border Grid.Row="0" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="btnOpen" Content="開啟日誌檔 (.log)" Click="BtnOpen_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnFill" Content="補齊資料" Click="BtnFill_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnRealtime" Content="連接即時行情" Click="BtnRealtime_Click" Padding="12,4" FontWeight="Bold" Background="{StaticResource SciFiActiveBg}" Margin="0,0,8,0"/>
                    <Button x:Name="btnUpdate" Content="更新" Click="BtnUpdate_Click" Margin="0,0,12,0"/>
                    
                    <CheckBox x:Name="chkTelegram" Content="啟用TG" Foreground="White" VerticalAlignment="Center" IsChecked="False" Margin="0,0,12,0"/>
                    
                    <!-- 隱藏的 WindowsFormsHost 用於承載元大 ActiveX 行情 COM 元件，物理不可見但事件在後台完美幫浦 -->
                    <WindowsFormsHost x:Name="comHost" Width="1" Height="1" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Label x:Name="lblRealtimeStatus" Content="未連線" Foreground="#EB4B4B" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}"/>
                    <Label x:Name="lblStatus" Content="  請選擇 event.log 檔案開始分析" Foreground="#0080FF" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 1. 復盤回放控制面板 ==================== -->
        <Border Grid.Row="1" Background="{StaticResource PanelDarkBg}" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="復盤日期:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Grid.Column="1" x:Name="txtReplayPath" MinWidth="80" IsReadOnly="True" VerticalAlignment="Center" Foreground="#00A2ED" FontWeight="Bold" Text="" Margin="0,0,6,0"/>
                <Button Grid.Column="2" x:Name="btnSelectReplayDir" Content="選擇資料夾" Click="BtnSelectReplayDir_Click" Margin="0,0,12,0"/>

                <Label Grid.Column="3" Content="盤別:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="4" x:Name="cboReplaySession" MinWidth="80" SelectedIndex="0" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ComboBoxItem Content="日盤"/>
                    <ComboBoxItem Content="夜盤"/>
                </ComboBox>

                <Button Grid.Column="5" x:Name="btnLoadReplay" Content="載入復盤" Click="BtnLoadReplay_Click" Foreground="#00A2ED" FontWeight="Bold" Margin="0,0,8,0"/>
                <Button Grid.Column="6" x:Name="btnPlayPause" Content="▶ 播放" Click="BtnPlayPause_Click" IsEnabled="False" Background="#005A9E" FontWeight="Bold" Padding="10,4" Margin="0,0,6,0"/>
                <Button Grid.Column="7" x:Name="btnStopReplay" Content="⏹ 停止" Click="BtnStopReplay_Click" IsEnabled="False" Background="#EB4B4B" FontWeight="Bold" Padding="10,4" Margin="0,0,12,0"/>

                <Label Grid.Column="8" Content="速度:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="9" x:Name="cboReplaySpeed" MinWidth="60" SelectedIndex="0" SelectionChanged="CboReplaySpeed_SelectionChanged" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ComboBoxItem Content="1x"/>
                    <ComboBoxItem Content="2x"/>
                    <ComboBoxItem Content="5x"/>
                    <ComboBoxItem Content="10x"/>
                    <ComboBoxItem Content="20x"/>
                    <ComboBoxItem Content="50x"/>
                    <ComboBoxItem Content="自訂"/>
                </ComboBox>

                <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="速度上限:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <!-- 使用 TextBox 搭配滾輪/修改，免除外部 NumericUpDown 依賴 -->
                    <TextBox x:Name="txtMaxSpeed" Text="100" MinWidth="45" TextAlignment="Center" VerticalAlignment="Center" LostFocus="TxtMaxSpeed_LostFocus"/>
                    <Label Content="x" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Slider 科幻進度條 -->
                <DockPanel Grid.Column="11" LastChildFill="True" VerticalAlignment="Center" Margin="10,0,8,0">
                    <Label Content="進度:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider x:Name="sldProgress" IsEnabled="False" VerticalAlignment="Center"
                            PreviewMouseDown="SldProgress_PreviewMouseDown"
                            PreviewMouseUp="SldProgress_PreviewMouseUp"
                            ValueChanged="SldProgress_ValueChanged"/>
                </DockPanel>

                <Label Grid.Column="12" x:Name="lblVirtualTime" Content="復盤時間: --:--:--" Foreground="#00A2ED" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ==================== 2. 速差與極值資訊區 ==================== -->
        <Border Grid.Row="2" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,0,0,1" Padding="0,6" Margin="0,4">
            <StackPanel Orientation="Vertical">
                <!-- 第一行：大台/小台基本速差 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" x:Name="lblSpeedTxf" Text="大臺: 外盤(買) --/筆 | 內盤(賣) --/筆 → --" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="lblSpeedMxf" Text="小臺: 外盤(買) --/筆 | 內盤(賣) --/筆 → --" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" VerticalAlignment="Center"/>
                </Grid>
                
                <!-- 第二行：極值資訊、共識、大台速差、小台速差、即時價 ＆ 設定參數項目 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左側資訊標籤們 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="tbPriceInfo" VerticalAlignment="Center">
                            <Run x:Name="runMaxInfo" Text="最高價: -- (--)" Foreground="#EB4B4B" FontWeight="Bold"/>
                            <Run Text=" | " Foreground="{StaticResource TextMuted}"/>
                            <Run x:Name="runMinInfo" Text="最低價: -- (--)" Foreground="#28A745" FontWeight="Bold"/>
                            <Run Text=" | " Foreground="{StaticResource TextMuted}"/>
                            <Run x:Name="runAmpInfo" Text="振幅: --" Foreground="#FFD700" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock x:Name="lblConsensusDir" Text="| 共識: --" Foreground="Gray" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblTxfNetSpeed" Text="| 大臺速差: --" Foreground="Gray" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblMxfNetSpeed" Text="| 小臺速差: --" Foreground="Gray" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblLivePrice" Text="| 成交價: --" Foreground="#00A2ED" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- 右側參數設定下拉選單 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Label Content="載入回測(天):" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="cboBacktestDays" MinWidth="55" SelectedIndex="1" SelectionChanged="CboBacktestDays_SelectionChanged" Margin="0,0,12,0">
                            <ComboBoxItem Content="30"/>
                            <ComboBoxItem Content="60"/>
                            <ComboBoxItem Content="120"/>
                            <ComboBoxItem Content="250"/>
                            <ComboBoxItem Content="全部"/>
                        </ComboBox>

                        <Label Content="小臺K線(分):" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="cboKlineInterval" MinWidth="45" SelectedIndex="0" SelectionChanged="CboKlineInterval_SelectionChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="15"/>
                            <ComboBoxItem Content="30"/>
                            <ComboBoxItem Content="60"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ==================== 3. 主要顯示區 (三段拉伸) ==================== -->
        <Grid Grid.Row="3" Margin="0,4">
            <Grid.RowDefinitions>
                <!-- Row 0: 日誌看板 -->
                <RowDefinition Height="1*"/>
                <!-- Row 1: K線圖 / 停損監控 -->
                <RowDefinition Height="2*"/>
                <!-- Row 2: 雙數據表格 -->
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>

            <!-- 3A. 日誌看板 與 區間統計 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,4,0">
                    <RichTextBox x:Name="txtOutput" IsReadOnly="True" Background="#1A1A1A" Foreground="#DCDCDC" 
                                 FontFamily="Consolas" FontSize="{DynamicResource GlobalFontSize}" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 PreviewMouseLeftButtonDown="TxtOutput_PreviewMouseLeftButtonDown"/>
                </Border>
                
                <GridSplitter Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#333" Margin="0,0,-2,0"/>

                <Border Grid.Column="1" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="4,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左側：帳號資訊與統計 -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 今日已平倉損益面板 -->
                            <Border Grid.Row="0" Background="#222222" Padding="6,4" Margin="4,2,4,4" CornerRadius="3" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Vertical">
                                    <Button x:Name="btnQueryPnL" Content="查詢" HorizontalAlignment="Left" Click="BtnQueryPnL_Click" Background="#333" Foreground="White" Padding="10,4" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="lblPnLAccount" Text="帳號: 未登入" Foreground="Gray" FontSize="{DynamicResource GlobalFontSize}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="今日已平倉損益: " Foreground="#DCDCDC" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblTodayPnL" Text="NT$ 0" Foreground="#DCDCDC" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="可動用保證金: " Foreground="#DCDCDC" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblMargin" Text="NT$ 0" Foreground="#DCDCDC" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="當前庫存: " Foreground="#DCDCDC" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="lblCurrentPosition" Text="無部位" Foreground="#DCDCDC" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="icIntervalStats" Padding="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" Cursor="Hand" MouseLeftButtonDown="IntervalStat_MouseLeftButtonDown">
                                                <TextBlock Text="{Binding DisplayText}" Foreground="{Binding DisplayColor}" Margin="0,2"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- 右側：帳務查詢日誌 -->
                        <Border Grid.Column="1" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1,0,0,0" Margin="4,0,0,0" Padding="4,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="帳務查詢日誌" Foreground="#0080FF" FontWeight="Bold" Margin="4,2,4,4" FontSize="{DynamicResource GlobalFontSize}"/>
                                <RichTextBox Grid.Row="1" x:Name="txtQueryOutput" IsReadOnly="True" Background="#1A1A1A" Foreground="#DCDCDC" 
                                             FontFamily="Consolas" FontSize="{DynamicResource GlobalFontSize}" BorderThickness="0"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 橫向拉伸條 1 -->
            <GridSplitter Grid.Row="0" Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="#333" Margin="0,0,0,-2"/>

            <!-- 3B. K線圖 / 停損監控 (2:1 比例) -->
            <Grid Grid.Row="1" Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- K線圖 -->
                <Border Grid.Column="0" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,4,0">
                    <controls:KLineChartControl x:Name="klineChart"/>
                </Border>

                <!-- 縱向拉伸條 -->
                <GridSplitter Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#333" Margin="0,0,-2,0"/>

                <!-- 停損監控 -->
                <Border Grid.Column="1" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="4,0,0,0">
                    <controls:UnbrokenKMonitor x:Name="wndUnbrokenK"/>
                </Border>
            </Grid>

            <!-- 橫向拉伸條 2 -->
            <GridSplitter Grid.Row="1" Height="4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="#333" Margin="0,0,0,-2"/>

            <!-- 3C. 雙數據表格 (1:1 比例) -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- K線表格 -->
                <Border Grid.Column="0" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,4,0">
                    <DataGrid x:Name="dgKline" BorderThickness="0" SelectionChanged="DgKline_SelectionChanged" PreviewMouseLeftButtonDown="DataGrid_CancelSelection" ClipboardCopyMode="IncludeHeader">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="Copy" Header="複製 (Copy)"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Resources>
                            <Style x:Key="ObsHighlightCellStyle" TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsObsKLowHighlight}" Value="True">
                                        <Setter Property="Background" Value="#28A745"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsObsKHighHighlight}" Value="True">
                                        <Setter Property="Background" Value="#EB4B4B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#DCDCDC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tag}" Value="up">
                                        <Setter Property="Foreground" Value="#EB4B4B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Tag}" Value="down">
                                        <Setter Property="Foreground" Value="#28A745"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="時間" Binding="{Binding TimeLabel}" Width="Auto" CellStyle="{StaticResource ObsHighlightCellStyle}"/>
                            <DataGridTextColumn Header="高" Binding="{Binding High}" Width="Auto" CellStyle="{StaticResource ObsHighlightCellStyle}"/>
                            <DataGridTextColumn Header="低" Binding="{Binding Low}" Width="Auto" CellStyle="{StaticResource ObsHighlightCellStyle}"/>
                            <DataGridTextColumn Header="開" Binding="{Binding Open}" Width="Auto" CellStyle="{StaticResource ObsHighlightCellStyle}"/>
                            <DataGridTextColumn Header="收" Binding="{Binding Close}" Width="Auto" CellStyle="{StaticResource ObsHighlightCellStyle}"/>
                            <DataGridTextColumn Header="訊號標記" Binding="{Binding Signals}" Width="*"/>
                            <DataGridTextColumn Header="突破上高" Binding="{Binding BreakHigh}" Width="Auto"/>
                            <DataGridTextColumn Header="跌破上低" Binding="{Binding BreakLow}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 縱向拉伸條 -->
                <GridSplitter Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#333" Margin="0,0,-2,0"/>

                <!-- 極值觀測表 -->
                <Border Grid.Column="1" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="4,0,0,0">
                    <DataGrid x:Name="dgObserver" BorderThickness="0" SelectionChanged="DgObserver_SelectionChanged" PreviewMouseLeftButtonDown="DataGrid_CancelSelection" ClipboardCopyMode="IncludeHeader">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="Copy" Header="複製 (Copy)"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{Binding ForegroundColor}"/>
                                <Setter Property="Background" Value="{Binding BackgroundColor}"/>
                                <Setter Property="FontWeight" Value="{Binding FontWeightVal}"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="選取" Width="Auto" MinWidth="45">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" 
                                                  IsEnabled="{Binding IsCheckable}" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  Cursor="Hand">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.25"/>
                                                            <Setter Property="Cursor" Value="Arrow"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="類型" Binding="{Binding DisplayTitle}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="A點時間" Binding="{Binding BestATimeDisplay}" Width="Auto" MinWidth="75"/>
                            <DataGridTextColumn Header="A點價" Binding="{Binding BestAPrice}" Width="Auto" MinWidth="55">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Padding" Value="5,0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                        <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTargetPriceHighlighted}" Value="True">
                                                <Setter Property="Background" Value="#FF00FF" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="B點時間" Binding="{Binding TrigTimeDisplay}" Width="Auto" MinWidth="75"/>
                            <DataGridTextColumn Header="觸發價" Binding="{Binding TrigPrice}" Width="Auto" MinWidth="55"/>
                            <DataGridTextColumn Header="前向平均" Binding="{Binding Pre}" Width="Auto" MinWidth="65"/>
                            <DataGridTextColumn Header="後向平均" Binding="{Binding Post}" Width="Auto" MinWidth="65"/>
                            <DataGridTextColumn Header="停損價" Binding="{Binding StopLossDisplay}" Width="Auto" MinWidth="95"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- ==================== 4. 底部觀察參數列 ==================== -->
        <Border Grid.Row="4" BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="spBottomBar" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Label x:Name="lblObsN" Content="觀察N: --" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>

                    <Label Content="最高觀察:" Foreground="White" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cboObsHigh" MinWidth="70" IsEditable="True" TextBoxBase.TextChanged="CboObsHigh_TextChanged" Margin="0,0,6,0"/>

                    <Label Content="做空觀察:" Foreground="White" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="txtObsHigh" MinWidth="60" VerticalAlignment="Center" KeyDown="TxtObsHigh_KeyDown" Margin="0,0,12,0"/>

                    <Label Content="最低觀察:" Foreground="White" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cboObsLow" MinWidth="70" IsEditable="True" TextBoxBase.TextChanged="CboObsLow_TextChanged" Margin="0,0,6,0"/>

                    <Label Content="做多觀察:" Foreground="White" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="txtObsLow" MinWidth="60" VerticalAlignment="Center" KeyDown="TxtObsLow_KeyDown" Margin="0,0,12,0"/>

                    <TextBlock x:Name="lblObsStatus" Text="觀察: 待設定" Foreground="Gray" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0">
                    <Label Content="下單品種:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <RadioButton x:Name="rbTX" Content="大臺" Foreground="White" GroupName="SymbolGroup" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton x:Name="rbMTX" Content="小臺" Foreground="White" GroupName="SymbolGroup" IsChecked="True" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
