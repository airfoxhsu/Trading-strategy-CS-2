<Application x:Class="ExtremeSignalAppCS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:ExtremeSignalAppCS"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- ==================== 動態字型大小資源 ==================== -->
        <sys:Double x:Key="GlobalFontSize">12</sys:Double>

        <!-- ==================== 暗黑科幻交易美學色彩系統 ==================== -->
        <SolidColorBrush x:Key="ExtremeDarkBg" Color="#121212"/>
        <SolidColorBrush x:Key="PanelDarkBg" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="WidgetBorderBrush" Color="#333333"/>
        <SolidColorBrush x:Key="SciFiGreen" Color="#00FFCC"/>
        <SolidColorBrush x:Key="BullRed" Color="#EB4B4B"/>
        <SolidColorBrush x:Key="BearGreen" Color="#28A745"/>
        <SolidColorBrush x:Key="TextLight" Color="#DCDCDC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#808080"/>
        
        <LinearGradientBrush x:Key="GlassyButtonBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2A2A" Offset="0"/>
            <GradientStop Color="#1A1A1A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SciFiActiveBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#005A9E" Offset="0"/>
            <GradientStop Color="#00A2ED" Offset="1"/>
        </LinearGradientBrush>

        <!-- ==================== 尊貴發光 Button 樣式 ==================== -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GlassyButtonBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource WidgetBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Microsoft JhengHei"/>
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SciFiGreen}"/>
                                <Setter TargetName="Border" Property="Background" Value="#252525"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#151515"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter TargetName="Border" Property="Background" Value="#111111"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== 發光 TextBox 樣式 ==================== -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WidgetBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Consolas, Microsoft JhengHei"/>
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SciFiGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== 暗黑 DataGrid 樣式 (極致流暢度優化) ==================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="RowBackground" Value="#151515"/>
            <Setter Property="AlternatingRowBackground" Value="#181818"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WidgetBorderBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#252525"/>
            <Setter Property="VerticalGridLinesBrush" Value="#252525"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <!-- DataGrid Header 樣式 -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Microsoft JhengHei"/>
        </Style>

        <!-- DataGrid Row 樣式 (選取發光) -->
        <Style TargetType="DataGridRow">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#252525"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00FFCC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1A1A1A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#DCDCDC"/>
            </Style.Resources>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ==================== TextBlock 全域樣式 ==================== -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
        </Style>

        <!-- ==================== Label 全域樣式 ==================== -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- ==================== ComboBox 全域樣式 ==================== -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
        </Style>

        <!-- ==================== CheckBox 全域樣式 ==================== -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="{DynamicResource GlobalFontSize}"/>
        </Style>
    </Application.Resources>
</Application>
